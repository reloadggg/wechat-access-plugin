{
  "name": "@fengcch/openclaw-wechat-access-plugin",
  "private": false,
  "version": "0.1.0",
  "description": "OpenClaw WeChat access plugin with terminal-first login and binding flow.",
  "type": "module",
  "main": "index.js",
  "license": "MIT",
  "author": "fengcch",
  "homepage": "https://github.com/reloadggg/wechat-access-plugin#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reloadggg/wechat-access-plugin.git"
  },
  "bugs": {
    "url": "https://github.com/reloadggg/wechat-access-plugin/issues"
  },
  "keywords": [
    "openclaw",
    "wechat",
    "plugin",
    "gateway",
    "remote-control"
  ],
  "files": [
    "index.js",
    "openclaw.plugin.json",
    "src",
    "scripts",
    "tools",
    "config.example.json",
    "wechat-access.local.example.json",
    "README.md"
  ],
  "openclaw": {
    "extensions": [
      "./index.js"
    ]
  },
  "scripts": {
    "setup": "node scripts/install-local.mjs && node tools/token-cli/serve.mjs --apply-config --bind",
    "setup:terminal": "node scripts/terminal-setup.mjs",
    "login": "node scripts/terminal-setup.mjs --skip-install",
    "login:browser": "node tools/token-cli/serve.mjs --apply-config --bind",
    "token": "node tools/token-cli/serve.mjs",
    "token:terminal": "node scripts/terminal-login.mjs",
    "token:setup": "node tools/token-cli/serve.mjs --apply-config --bind",
    "bind-link": "node scripts/bind-link.mjs",
    "apply-config": "node scripts/apply-config.mjs",
    "install-local": "node scripts/install-local.mjs"
  },
  "dependencies": {
    "ws": "^8.18.0",
    "qrcode-terminal": "^0.12.0",
    "jpeg-js": "^0.4.4",
    "pngjs": "^7.0.0"
  }
}
